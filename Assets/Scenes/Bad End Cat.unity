  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Constance can\u2019t shake the wrongness, \nshe listens in horror as the
    Cat\u2019s voice flits in and out of focus, \nbits and pieces about games, about
    power, \nabout the connection being strong. \nWhat does any of it mean?\r\n"
  m_isRightToLeft: 0

  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "When she turns to argue she realizes the guards \nhave already locked
    her in and left. \nWith a huff she settles into the corner and decides to wait.\r\n\nShe
    waits, and waits, and continues to wait. \nNo one comes to check on her, no one
    comes to visit or rescue her. \nShe sits, the silence feels suffocating."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}
  m_sharedMaterial: {fileID: 3908959653227688014, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}

  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The world warps, colors falling in on themselves. \n\nShe thinks she see's
    dusty mirrors in the distacne. \n\nShe watches in horror as her own face is reflected
    on these surfaces,\r\n\ncracked, broken and dishelved. \r\n\n"
  m_isRightToLeft: 0

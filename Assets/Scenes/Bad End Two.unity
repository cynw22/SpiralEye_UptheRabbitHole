  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\rShe runs endlessly, eyes burning into her. \nShe feels the mirrors taunting
    her from the distance. \n\nEach step slowly drains her. She knows, doesn\u2019t
    have to see it \nto know that the faces all stare back at her, judging. \n\r\nThere
    is no way out, this is it, the end of the line. \nShe made the wrong choice\u2026\r\n\n\r\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}

  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "She brushes it off and walks forward into the hallway, pictures line the
    walls. \n\nShe watches figures blur past her.\r\n\nPeople smiling, laughing,
    enjoying life. \nThe air feels lighter, the sun brighter.\n"
  m_isRightToLeft: 0

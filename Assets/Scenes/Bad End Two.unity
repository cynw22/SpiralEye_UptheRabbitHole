  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "She walks further down, watching the colors fade, \nthe smiles dull, the
    light slowly fade. \nConfused, she walks around, eyes searching.\n\nThe Queen
    appears once more, however this time her eyes look crazed, there\u2019s something
    different in the way she stands.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}

      m_Calls: []
  m_text: "\rShe knows she should stay awake, keep watch in this strange world, but
    for some reason her eyes feel heavy.\r\n\nAs she feels her eyes slowly slip closed
    she thinks to herself, just ten minutes, she\u2019ll wake them up in ten.\r\n\r\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}

      m_Calls: []
  m_text: "They walk for what feels like hours, the trees stretching forward in an
    endless line.\n \r\nFinally Alice begs her sister to take a break, \nher feet
    hurt and she wants to rest. \nFor once Constance doesn\u2019t argue with her
    sister.\r\n\n\n\n\n\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f054b46c0710ea94ea7443ff1dbe58bd, type: 2}

  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "They're siblings, they were supposed to be a team! \r\n\nSo why did it
    feel like they failed? \nWhy did it feel like they were missing a piece of themself?
    \nWhy was this separation stifling? \n\nIn the end the silence was all that answered
    back\u2026\r\n"
